# Supabase Configuration
# Publicly available URL for the Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publicly available anonymous key for client-side access
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Server-side secret key for administrative operations (not exposed to client)
# Only used in seed script and server-side operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_key_here
